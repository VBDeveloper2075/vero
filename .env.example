# ──────────────────────────────────────────────────────────────────
#  CONFIGURACIÓN DEL BACKEND
# ──────────────────────────────────────────────────────────────────
#  1. Seguí los pasos del README.md para deployar apps-script/Code.gs
#  2. Pegá la URL de la Web App y el ID de tu Google Sheet
#  3. Renombrá este archivo a  .env  (sin el .example)
#
#  ⚠️  NUNCA subas el archivo .env a Git — ya está en .gitignore
# ──────────────────────────────────────────────────────────────────

# URL de tu Web App de Google Apps Script (termina en /exec)
VITE_BACKEND_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec

# ID de tu Google Spreadsheet
# Lo encontrás en la URL: /spreadsheets/d/ESTE_ES_EL_ID/edit
VITE_SHEET_BASE=https://docs.google.com/spreadsheets/d/TU_SPREADSHEET_ID/edit#gid=
